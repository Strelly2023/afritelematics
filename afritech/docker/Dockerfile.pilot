FROM python:3.11-slim

WORKDIR /app

COPY pyproject.toml .
COPY afritech ./afritech
COPY ecosystems ./ecosystems
COPY afriride_system ./afriride_system

RUN pip install --no-cache-dir fastapi uvicorn pydantic jsonschema

CMD ["uvicorn", "afritech.api.app:app", "--host", "0.0.0.0", "--port", "8000"]
