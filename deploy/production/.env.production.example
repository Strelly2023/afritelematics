AFRITECH_DOMAIN=your-domain.example
AFRITECH_JWT_SECRET=replace-with-production-jwt-secret
AFRITECH_EVENT_INGESTION_SECRET=replace-with-production-event-secret
AFRIRIDE_JWT_SECRET=replace-with-production-afriride-jwt-secret
AFRIRIDE_EVENT_INGESTION_SECRET=replace-with-production-afriride-event-secret
AFRIRIDE_DJANGO_SECRET_KEY=replace-with-production-django-secret
AFRIRIDE_AUDIT_API_KEY=replace-with-production-audit-api-key
AFRITECH_SIGNING_PRIVATE_KEY_PATH=/run/secrets/afritech_private_key.pem
AFRITECH_SIGNING_PUBLIC_KEY_PATH=/run/secrets/afritech_public_key.pem
VITE_AFRIRIDE_API_URL=https://your-domain.example
VITE_AFRIRIDE_APP_VERSION=production-1

# Chain publication is disabled until Sepolia deployment is complete.
AFRITECH_CHAIN_MODE=sepolia
AFRITECH_CHAIN_NETWORK=sepolia
AFRITECH_CHAIN_RPC_URL_SEPOLIA=https://sepolia.infura.io/v3/replace-with-provider-key
AFRITECH_CHAIN_PRIVATE_KEY_PATH=/run/secrets/eth_private_key
AFRITECH_CHAIN_ADDRESS_CHECKSUM=0xYOUR_FUNDED_SEPOLIA_WALLET
AFRITECH_CHAIN_ID=11155111
AFRITECH_CHAIN_CONTRACT_ADDRESS=0xYOUR_DEPLOYED_ARCHITECTURE_ANCHOR
AFRITECH_CHAIN_ENABLE_PUBLISH=false
AFRITECH_CHAIN_TX_TIMEOUT=60
AFRITECH_CHAIN_GAS_PRICE_GWEI=2
