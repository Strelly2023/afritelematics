AFRITECH_JWT_SECRET=replace-with-staging-jwt-secret
AFRITECH_EVENT_INGESTION_SECRET=replace-with-staging-event-secret
AFRIRIDE_JWT_SECRET=replace-with-staging-afriride-jwt-secret
AFRIRIDE_EVENT_INGESTION_SECRET=replace-with-staging-afriride-event-secret
AFRIRIDE_DJANGO_SECRET_KEY=replace-with-staging-django-secret
AFRIRIDE_AUDIT_API_KEY=replace-with-staging-audit-api-key
AFRITECH_SIGNING_PRIVATE_KEY_PATH=/run/secrets/afritech_private_key.pem
AFRITECH_SIGNING_PUBLIC_KEY_PATH=/run/secrets/afritech_public_key.pem
VITE_AFRIRIDE_API_URL=https://staging.afritech.example
VITE_AFRIRIDE_APP_VERSION=staging-1
