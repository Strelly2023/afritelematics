FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app

COPY pyproject.toml README.md /app/
COPY afritech /app/afritech
COPY afriride_system /app/afriride_system
COPY ecosystems /app/ecosystems
COPY docs /app/docs

RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir . uvicorn

EXPOSE 8000

CMD ["uvicorn", "afritech.api.app:app", "--host", "0.0.0.0", "--port", "8000"]
